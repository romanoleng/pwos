# PWOS environment (CLAUDE.md §9)
# Server-side only. None of these may ever be prefixed NEXT_PUBLIC_ — src/lib/server/env.ts
# throws at boot if they are.
#
# Copy to .env.local for local dev, and add the same values in Vercel →
# Project → Settings → Environment Variables. .env* is gitignored.

# Airtable scoped Personal Access Token for base appL4V6tbsGRJ7WxQ.
# Create at airtable.com → Builder hub → Personal access tokens.
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=appL4V6tbsGRJ7WxQ

# Optional. CoinGecko's public tier is enough for V1 — leave blank unless you
# hit rate limits and upgrade to a Pro/Demo key.
PRICE_API_KEY=

# Session signing key, 32+ chars. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Your single-user login password.
APP_PASSWORD=

# Neon Postgres — the app's database. Use the POOLED connection string.
DATABASE_URL=
